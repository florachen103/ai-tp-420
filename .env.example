# ================== 后端 ==================
# 应用
APP_ENV=development
APP_SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:3000

# 数据库 (PostgreSQL + pgvector)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=training
POSTGRES_USER=training
POSTGRES_PASSWORD=training_dev_pwd

# Redis (缓存 + Celery broker)
REDIS_HOST=redis
REDIS_PORT=6379

# 对象存储 (MinIO 本地开发 / 生产可换阿里云OSS/腾讯云COS/AWS S3)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=training-materials
S3_REGION=us-east-1
S3_USE_SSL=false

# ================== AI 提供商 ==================
# 支持: deepseek | openai | qwen | custom
AI_PROVIDER=deepseek
AI_MODEL_CHAT=deepseek-chat
AI_MODEL_EMBEDDING=text-embedding-v2

# DeepSeek (默认，性价比最高)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 阿里通义 DashScope（必填：当 AI_PROVIDER=deepseek 时，向量化 embedding 走百炼，与 DeepSeek 无关）
# 在 https://dashscope.console.aliyun.com/apiKey 创建 API-KEY，整行粘贴 sk- 开头密钥；勿加引号、勿多空格。
# 若出现 401：密钥错误、子账号无权限、或需先在控制台开通「文本向量」模型。
DASHSCOPE_API_KEY=sk-your-dashscope-key

# PDF OCR 兜底（扫描版 PDF 无文字层时自动 OCR，再切片）
PDF_OCR_FALLBACK_ENABLED=true
PDF_OCR_LANG=chi_sim+eng
PDF_OCR_DPI=220
PDF_OCR_MAX_PAGES=120

# OpenAI (可选)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ================== 邮件服务（邮箱注册验证码） ==================
# 本地开发默认推荐 Mailpit：docker compose 后访问 http://localhost:8025 查看验证码邮件
SMTP_ENABLED=true
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@localhost
SMTP_USE_TLS=false
SMTP_USE_SSL=false

# 注册验证码配置
AUTH_REGISTER_CODE_TTL_MINUTES=10
AUTH_REGISTER_CODE_RESEND_SECONDS=60

# ================== 前端 ==================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=AI 培训平台
